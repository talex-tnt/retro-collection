rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() &&
        request.auth.uid == userId;
    }

    function canAccess(userId) {
      return isOwner(userId) || isAdmin();
    }

    function validString(field, maxLength) {
      return field is string &&
        field.size() > 0 &&
        field.size() <= maxLength;
    }

    function validOptionalString(field, maxLength) {
      return !(field is string) ||
        field.size() <= maxLength;
    }

    function validItem(data, userId) {
      return
        data.keys().hasOnly([
          'title',
          'description',
          'platform',
          'imageUrl',
          'createdAt',
          'updatedAt',
          'userId'
        ]) &&
        validString(data.title, 100) &&
        validOptionalString(data.description, 1000) &&
        validString(data.platform, 50) &&
        (!('imageUrl' in data) ||
          validOptionalString(data.imageUrl, 500)) &&
        data.userId == userId;
    }

    function validCollection(data, userId) {
      return
        data.keys().hasOnly([
          'name',
          'description',
          'createdAt',
          'updatedAt',
          'userId'
        ]) &&
        validString(data.name, 100) &&
        validOptionalString(data.description, 500) &&
        data.userId == userId;
    }

    match /authorized-users/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {

      allow get, list: if canAccess(userId);
      allow create, update: if canAccess(userId);
      allow delete: if isAdmin();

      match /items/{itemId} {
        allow get, list: if canAccess(userId);
        allow create: if canAccess(userId) && validItem(request.resource.data, userId);
        allow update: if canAccess(userId) && validItem(request.resource.data, userId);
        allow delete: if canAccess(userId);
      }

      match /collections/{collectionId} {
        allow get, list: if canAccess(userId);
        allow create: if canAccess(userId) && validCollection(request.resource.data, userId);
        allow update: if canAccess(userId) && validCollection(request.resource.data, userId);
        allow delete: if canAccess(userId);

        match /items/{itemId} {
          allow get, list: if canAccess(userId);
          allow create: if canAccess(userId) && validItem(request.resource.data, userId);
          allow update: if canAccess(userId) && validItem(request.resource.data, userId);
          allow delete: if canAccess(userId);
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}