rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@gmail.com';
    }

    match /authorized-users/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Users may read and update their own user profile, or admin may access everything.
      allow get, list: if request.auth.uid == userId || isAdmin();
      allow create, update, delete: if request.auth.uid == userId || isAdmin();

      match /items/{itemId} {
        allow get, list: if request.auth.uid == userId || isAdmin();
        allow create, update, delete: if request.auth.uid == userId || isAdmin();
      }

      match /collections/{collectionId} {
        allow get, list: if request.auth.uid == userId || isAdmin();
        allow create, update, delete: if request.auth.uid == userId || isAdmin();

        match /items/{itemId} {
          allow get, list: if request.auth.uid == userId || isAdmin();
          allow create, update, delete: if request.auth.uid == userId || isAdmin();
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
