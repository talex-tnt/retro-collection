{
  "scripts": {
    "login": "firebase login",
    "deploy:firestore": "dotenv -e .env -- sh -c 'firebase deploy --only firestore --project=$ENV'",
    "deploy:indexes": "dotenv -e .env -- sh -c 'firebase deploy --only firestore:indexes --project=$ENV'",
    "deploy": "dotenv -e .env -- sh -c 'echo $ENV && firebase deploy --project=$ENV'",
    "deploy:ci": "firebase deploy --project $ENV",
    "init:main": "dotenv -e .env -- node init-main-db.mjs",
    "set-admin": "node set-admin.mjs",
    "list:indexes": "dotenv -e .env -- sh -c 'firebase firestore:indexes --project=$ENV'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:rules": "node --test tests/*-firestore.rules.*.test.mjs",
    "test:rules:emulator:all": "RULES_TARGET=emulator firebase emulators:exec --only auth,firestore 'node --test tests/*-firestore.rules.*.test.mjs'",
    "test:rules:emulator:misc": "RULES_TARGET=emulator firebase emulators:exec --only auth,firestore 'node --test tests/3-firestore.rules.misc.test.mjs'",
    "test:rules:emulator:collections": "RULES_TARGET=emulator firebase emulators:exec --only auth,firestore 'node --test tests/1-firestore.rules.collections.test.mjs'",
    "test:rules:live:all": "RULES_TARGET=live ENV=dev node --test tests/*-firestore.rules.*.test.mjs",
    "test:rules:emulator:items": "sh -c 'RULES_TARGET=emulator firebase emulators:exec --only auth,firestore \"node --test tests/2-firestore.rules.items.test.mjs $*\"' sh",
    "test:rules:live:misc": "RULES_TARGET=live ENV=dev node --test tests/3-firestore.rules.misc.test.mjs",
    "test:rules:live:collections": "RULES_TARGET=live ENV=dev node --test tests/1-firestore.rules.collections.test.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^15.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
