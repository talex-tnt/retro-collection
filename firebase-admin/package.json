{
  "scripts": {
    "login": "firebase login",
    "deploy:firestore": "dotenv -e .env -- sh -c 'firebase deploy --only firestore --project=$ENV'",
    "deploy:indexes": "dotenv -e .env -- sh -c 'firebase deploy --only firestore:indexes --project=$ENV'",
    "deploy": "dotenv -e .env -- sh -c 'echo $ENV && firebase deploy --project=$ENV'",
    "deploy:ci" : "firebase deploy --project $ENV",
    "init:main": "dotenv -e .env -- node init-main-db.mjs",
    "set-admin": "node set-admin.mjs",
    "list:indexes": "dotenv -e .env -- sh -c 'firebase firestore:indexes --project=$ENV'",
    "test:rules": "node --test tests/firestore.rules.*.test.mjs",
    "test:rules:emulator:all": "RULES_TARGET=emulator firebase emulators:exec --only auth,firestore 'node --test tests/firestore.rules.*.test.mjs'",
    "test:rules:emulator:misc": "RULES_TARGET=emulator firebase emulators:exec --only auth,firestore 'node --test tests/firestore.rules.misc.test.mjs'",
    "test:rules:emulator:collections": "RULES_TARGET=emulator firebase emulators:exec --only auth,firestore 'node --test tests/firestore.rules.collections.test.mjs'",
    "test:rules:live:all": "RULES_TARGET=live ENV=dev node --test tests/firestore.rules.*.test.mjs",
    "test:rules:live:misc": "RULES_TARGET=live ENV=dev node --test tests/firestore.rules.misc.test.mjs",
    "test:rules:live:collections": "RULES_TARGET=live ENV=dev node --test tests/firestore.rules.collections.test.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^15.17.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
