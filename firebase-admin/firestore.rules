rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isAllowedResourceType(resourceType) {
      return resourceType in ['collections', 'items'];
    }

    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    function hasOnlyValidKeys(data, validKeys) { 
      // Ensure that the data contains only the expected keys (no extraneous fields)
      return data.keys().hasOnly(validKeys);
    }
    function hasAllRequiredKeys(data, requiredKeys) {
      // Ensure that the data contains all required keys
      return data.keys().hasAll(requiredKeys);
    }
    function hasOnlyAffectedKeys(newData, existingData, validKeys) {
      return newData.diff(existingData).affectedKeys().hasOnly(validKeys);
    }
    function hasAllRequiredAffectedKeys(newData, existingData, requiredKeys) {
      return newData.diff(existingData).affectedKeys().hasAll(requiredKeys);
    }

    function validString(field, maxLength) {
      return field is string && field.size() > 0 && field.size() <= maxLength;
    }

    function validOptionalString(field, maxLength) {
      return field == null || (field is string && field.size() <= maxLength);
    }

    function hasValidOptionalString(data, field, maxLength) {
      return !(field in data) || data[field] == null || validOptionalString(data[field], maxLength);
    }

    function hasValidRequiredString(data, field, maxLength) {
      return (field in data) && validString(data[field], maxLength);
    }


    function validTimestamp(field) {
      return field is timestamp && 
        field.toMillis() > 0 &&
        field.toMillis() < request.time.toMillis() + 60000; // Allow up to 60 seconds in the future for clock skew
    }

    function tokenEmail() {
      return (isAuthenticated() && ('email' in request.auth.token) && request.auth.token.email is string)
        ? request.auth.token.email
        : (isAuthenticated() && ('authEmail' in request.auth.token) && request.auth.token.authEmail is string)
          ? request.auth.token.authEmail
          : null;
    }

    function isPubliclyVisible() {
      return resource != null &&
        resource.data != null &&
        ('visibility' in resource.data) &&
        (resource.data.visibility is map) &&
        ('public' in resource.data.visibility) &&
        resource.data.visibility.public == true;
    }

    function isValidVisibilityMap(data) {
      return (data is map) &&
        data.keys().hasOnly(['public']) &&
        ('public' in data) &&
        data.public is bool;
    }
    function isValidVisibilityMapOptional(data) {
      return !('visibility' in data) || data.visibility == null || isValidVisibilityMap(data.visibility);
    }

    function hasValidNickname(data) {
      return ('nickname' in data) && validString(data.nickname, 50);
    }

    function hasValidOptionalNickname(data) {
      return !('nickname' in data) || data.nickname == null || hasValidNickname(data);
    }

    function isPublicVisibilityEnabled(data) {
      return ('visibility' in data) &&
        isValidVisibilityMap(data.visibility) &&
        data.visibility.public == true;
    }

    function isValidPublicUserData(data) {
      return data.keys().hasOnly(['name', 'visibility', 'nickname']) &&
        validString(data.name, 100) &&
        isValidVisibilityMapOptional(data) &&
        hasValidOptionalNickname(data) &&
        (!isPublicVisibilityEnabled(data) || hasValidNickname(data));
    }

    function isValidPrivateUserData(data) {
      return data.keys().hasOnly(['email', 'lastLogin']) &&
        validOptionalString(data.email, 100) &&
        validTimestamp(data.lastLogin);
    }


    // Canonical root: /{env}/...
    // Public runtime config doc
    match /{env}/config/public/runtime {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // All other config paths are admin-only
    match /{env}/config/{document=**} {
      allow read, write: if isAdmin();
    }

    // Admin-only scratch area for tests and diagnostics
    match /test/testData/{document=**} {
      allow read, write: if isAdmin();
    }

    // Folder documents themselves are not user-writable
    match /{env}/data/{folder} {
      allow read, list, write: if isAdmin();
      
      function folderMatchesConfig() {
        return get(/databases/$(database)/documents/$(env)/config/public/runtime).data.dataFolder == folder;
      }

      // authorized-users: admin-only read/write (login allowlist)
      match /private/authorized-users/{email} {
        // Allow a signed-in user to check *only their own* authorization doc.
        // This enables a client-side allowlist check without permitting enumeration.
        allow get: if isAdmin() || (
          folderMatchesConfig() &&
          isAuthenticated() &&
          tokenEmail() != null &&
          tokenEmail().lower() == email.lower()
        );
        allow list: if isAdmin();
        allow write: if isAdmin();
      }

      // users public profile: owner writes only name + visibility.public; others may read only when public
      match /public/users/{userId} {
        allow get: if isAdmin() || (folderMatchesConfig() && (isOwner(userId) || isPubliclyVisible()));
        // For list/query: non-admins may only read public profiles.
        // Firestore evaluates this per returned document, so queries succeed only when
        // every document in the result set is publicly visible.
        allow list: if isAdmin() || (folderMatchesConfig() && isPubliclyVisible());
        allow create: if isAdmin() || (
          isOwner(userId) &&
          folderMatchesConfig() &&
          isValidPublicUserData(request.resource.data)
        );
        allow update: if isAdmin() || (
          isOwner(userId) &&
          folderMatchesConfig() &&
          isValidPublicUserData(request.resource.data)
        );
        allow delete: if isAdmin();
      }

      // users private profile: owner-only read/write for email + lastLogin
      match /private/users/{userId} {
        allow get: if isAdmin() || (folderMatchesConfig() && isOwner(userId));
        allow list: if isAdmin();
        allow create: if isAdmin() || (
          isOwner(userId) &&
          folderMatchesConfig() &&
          isValidPrivateUserData(request.resource.data)
        );
        allow update: if isAdmin() || (
          isOwner(userId) &&
          folderMatchesConfig() &&
          isValidPrivateUserData(request.resource.data)
        );
        allow delete: if isAdmin();
      }

      // collection helpers --------------------------------------------
      function getLengthLimit(field) {
        return (field == 'collection.name') ? 100 :
               (field == 'collection.description') ? 500 : 0;
      }
      function createCollectionKeys() {
        return ['name', 'userId', 'createdAt', 'description', 'visibility'];
      }
      function createCollectionRequiredKeys() {
       return ['name', 'userId', 'createdAt', 'visibility'];
      }
      function validCollectionCreate(data) {
        return isAdmin() ||
          isAuthenticated() &&
          hasOnlyValidKeys(data, createCollectionKeys()) &&
          hasAllRequiredKeys(data, createCollectionRequiredKeys()) &&
          isOwner(data.userId) &&
          validString(data.name,  getLengthLimit('collection.name')) &&
          validTimestamp(data.createdAt) &&
          isValidVisibilityMap(data.visibility) &&
          hasValidOptionalString(data, 'description', getLengthLimit('collection.description'));
      }
      function updateCollectionKeys() {
        return ['name', 'updatedAt', 'description', 'visibility'];
      }
      function updateCollectionRequiredKeys() {
        return ['updatedAt'];
      }
      function validCollectionUpdate(newData, existingData) {
        return isAdmin() ||
          isAuthenticated() &&
          existingData != null &&
          hasOnlyAffectedKeys(newData, existingData, updateCollectionKeys()) &&
          hasAllRequiredAffectedKeys(newData, existingData, updateCollectionRequiredKeys()) &&
          isOwner(existingData.userId) &&
          newData.userId == existingData.userId &&
          newData.createdAt == existingData.createdAt &&
          validTimestamp(newData.updatedAt) &&
          hasValidOptionalString(newData, 'name', getLengthLimit('collection.name')) &&
          hasValidOptionalString(newData, 'description', getLengthLimit('collection.description')) &&
          isValidVisibilityMapOptional(newData.visibility);
      }

      match /public/collections/{collectionId} {
        allow get: if isAdmin() || (folderMatchesConfig() && (isOwner(resource.data.userId) || isPubliclyVisible()));
        allow list: if isAdmin() || (folderMatchesConfig() && (isOwner(resource.data.userId) || isPubliclyVisible()));
        //
        allow create: if validCollectionCreate(request.resource.data);
        allow update: if validCollectionUpdate(request.resource.data, resource.data);
        allow delete: if isOwner(resource.data.userId) || isAdmin();
      }

      // ----------------------------------------------------------------


        match /public/items/{itemId} {
          allow get, list, create, update, delete: if true; // fixme: implement item rules
        }

      // Nickname index: track nicknames and their owners
      // Users can read any nickname doc, but can only write/delete if it contains their own userId
      match /public/nicknameIndex/{nickname} {
        allow get, list: if isAdmin() || (folderMatchesConfig() && isAuthenticated());
        allow create: if isAdmin() || (
          folderMatchesConfig() &&
          isAuthenticated() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.userId is string
        );
        allow update: if isAdmin() || (
          folderMatchesConfig() &&
          isAuthenticated() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.userId is string
        );
        allow delete: if isAdmin() || (
          folderMatchesConfig() &&
          isAuthenticated() &&
          resource.data.userId == request.auth.uid
        );
      }

      // Actual user data lives in collections under the folder doc
      // match /public/{resourceType}/{document=**} {
      //   allow read, list, write: if isAdmin() || (
      //     isAuthenticated() &&
      //     isAllowedResourceType(resourceType) &&
      //     folderMatchesConfig()
      //   );
      // }
    }
// #################################################################################################
// DEBUGGING: lock down all public collection access to verify test behavior when rules are correctly applied.
    // match /{env}/data/{folder}/public/collections/{document=**} {
    //       allow read, list: if false;
    //       allow write: if true;
    // }

    // match /{env}/data/{folder} {
    //   allow read, list, write: if isAdmin();
    //   match /public/collections/{collectionId} {
    //     allow list: if isAdmin() || (folderMatchesConfig() && (isOwner(resource.data.userId) || isPubliclyVisible()));
    //     // allow list: if isAdmin() || ((isOwner(resource.data.userId) || isPubliclyVisible()));
    //     // allow list: if false;
    //     // allow read, list: if false;
    //     allow write: if true;
    //   }
    // }
// ######################################################################################################################################

    // function validCollection(data, ownerId) {
    //   return data.keys().hasAll(['name', 'userId', 'createdAt']) &&
    //     validString(data.name, 100) &&
    //     (!('description' in data) || validOptionalString(data.description, 500)) &&
    //     data.userId == ownerId &&
    //     (!('visibility' in data) || validVisibility(data.visibility)) &&
    //     validTimestamp(data.createdAt);
    // }

    // function validItem(data, ownerId) {
    //   return data.keys().hasAll(['name', 'userId', 'createdAt']) &&
    //     validString(data.name, 100) &&
    //     (!('description' in data) || validOptionalString(data.description, 1000)) &&
    //     data.userId == ownerId &&
    //     (!('collectionId' in data) || data.collectionId == null || data.collectionId is string) &&
    //     (!('visibility' in data) || validVisibility(data.visibility)) &&
    //     validTimestamp(data.createdAt);
    // }

    // function hasValidItemCollection(data, ownerId) {
    //   return !('collectionId' in data) || data.collectionId == null || (
    //     data.collectionId is string && 
    //     data.collectionId.size() > 0 &&
    //     exists(/databases/$(database)/documents/collections/$(data.collectionId)) &&
    //     get(/databases/$(database)/documents/collections/$(data.collectionId)).data.userId == ownerId
    //   );
    // }

    // function normalizedCollectionId(data) {
    //   return ('collectionId' in data && data.collectionId != null) ? data.collectionId : null;
    // }

    // function validCollectionUpdate(data, ownerId) {
    //   return data.userId == ownerId &&
    //     validString(data.name, 100) &&
    //     (!('description' in data) || validOptionalString(data.description, 500)) &&
    //     data.createdAt == resource.data.createdAt &&
    //     (!('visibility' in data) || validVisibility(data.visibility)) &&
    //     (!('updatedAt' in data) || validTimestamp(data.updatedAt));
    // }

    // function validItemUpdate(data, ownerId) {
    //   return data.userId == resource.data.userId &&
    //     data.userId == ownerId &&
    //     data.createdAt == resource.data.createdAt &&
    //     (
    //       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['name']) ||
    //       validString(data.name, 100)
    //     ) &&
    //     (
    //       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['description']) ||
    //       validOptionalString(data.description, 1000)
    //     ) &&
    //     (
    //       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['collectionId']) ||
    //       hasValidItemCollection(data, ownerId)
    //     ) &&
    //     (
    //       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['visibility']) ||
    //       validVisibility(data.visibility)
    //     ) &&
    //     (!('updatedAt' in data) || validTimestamp(data.updatedAt));
    // }

    // function isCollectionQueryForCurrentUser() {
    //   return (request.query.where.size() == 1 &&
    //     request.query.where[0].field == 'userId' &&
    //     request.query.where[0].value == request.auth.uid) ||
    //     request.query.where.size() == 0;
    // }

    // function isItemsQueryForOwnedCollection() {
    //   return (request.query.where.size() == 1 &&
    //     request.query.where[0].field == 'collectionId' &&
    //     get(/databases/$(database)/documents/collections/$(request.query.where[0].value)).data.userId == request.auth.uid) ||
    //     request.query.where.size() == 0;
    // }
   

    // match /collections/{collectionId} {
    //   allow get: if isAdmin() || resource.data.userId == request.auth.uid || ('visibility' in resource.data && resource.data.visibility.public == true);
    //   allow list: if isAdmin() || isAuthenticated();
    //   allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid &&
    //     request.resource.data.keys().hasAll(['name', 'userId', 'createdAt']) && validCollection(request.resource.data, request.auth.uid);
    //   allow update: if (isOwner(resource.data.userId) && validCollectionUpdate(request.resource.data, request.auth.uid)) || isAdmin();
    //   allow delete: if isOwner(resource.data.userId) || isAdmin();
    // }

    // match /items/{itemId} {
    //   allow get: if isAdmin() || resource.data.userId == request.auth.uid || ('visibility' in resource.data && resource.data.visibility.public == true);
    //   allow list: if isAdmin() || isAuthenticated();
    //   allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid &&
    //     request.resource.data.keys().hasAll(['name', 'userId', 'createdAt']) &&
    //     validItem(request.resource.data, request.auth.uid) &&
