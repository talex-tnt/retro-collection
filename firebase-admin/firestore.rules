    // function hasValidItemCollection(data, ownerId) {
    //   return !('collectionId' in data) || data.collectionId == null || (
    //     data.collectionId is string && 
    //     data.collectionId.size() > 0 &&
    //     exists(/databases/$(database)/documents/collections/$(data.collectionId)) &&
    //     get(/databases/$(database)/documents/collections/$(data.collectionId)).data.userId == ownerId
    //   );
