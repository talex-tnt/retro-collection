    // function validCollectionUpdate(data, ownerId) {
    //   return data.userId == ownerId &&
    //     validString(data.name, 100) &&
    //     (!('description' in data) || validOptionalString(data.description, 500)) &&
    //     data.createdAt == resource.data.createdAt &&
    //     (!('visibility' in data) || validVisibility(data.visibility)) &&
    //     (!('updatedAt' in data) || validTimestamp(data.updatedAt));
