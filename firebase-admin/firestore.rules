/**
 * FIRESTORE RULES WITH TEST CASE MAPPING
 * 
 * This file maps Firestore security rules to their corresponding test cases.
 * Test case format: x.y.z where x=suite, y=group, z=test number
 * 
 * RULE MAPPING TABLE:
 * =====================================================
 * SUITE 1: AUTHORIZED-USERS
 * 1.1.1 - admin-only read/write on /private/authorized-users/{email}
 * 1.1.2 - legacy root collection query is denied
 * 1.1.3 - admin can list from canonical docs-root path
 * 
 * SUITE 2: ITEMS CRUD
 * 2.1.1 - admin can read any item
 * 2.1.2 - owner can read own item
 * 2.1.3 - non-owner cannot read private item
 * 2.1.4 - authenticated non-owner can read public item
 * 2.2.1 - owner can create own item
 * 2.2.2 - non-owner cannot create item for another user
 * 2.2.3 - unauthenticated cannot create item
 * 2.2.4 - admin can bypass all validation
 * 2.3.1 - rejects missing required name field
 * 2.3.2 - rejects missing required createdAt
 * 2.3.3 - rejects missing required visibility
 * 2.3.4 - name cannot exceed 100 characters
 * 2.3.5 - collectionId is required and must be non-empty string
 * 2.3.6 - description cannot exceed 1000 characters
 * 2.3.7 - rejects invalid visibility map
 * 2.3.8 - rejects non-timestamp createdAt
 * 2.4.1 - owner can update own item
 * 2.4.2 - non-owner cannot update item
 * 2.5.1 - updatedAt is required
 * 2.5.2 - name is optional in updates
 * 2.5.3 - description is optional in updates
 * 2.5.4 - visibility is optional in updates
 * 2.5.5 - name cannot exceed 100 characters on update
 * 2.6.1 - owner can delete own item
 * 2.6.2 - non-owner cannot delete item
 * 2.6.3 - admin can delete any item
 * 2.1.1 (query) - items query reproduces the frontend getItems shape
 * 
 * SUITE 3: INFRASTRUCTURE & CROSS-CUTTING RULES
 * 3.1.1 - admin can write to test/testData/rulesSmoke
 * 3.1.2 - non-admin cannot write to test data path
 * 3.1.3 - admin can write to test/config/public/runtime
 * 3.1.4 - non-admin cannot write to test config path
 * 3.1.5 - USERS (non-testers) cannot read/write to /test folder
 * 3.1.6 - TESTERS cannot read/write to /main folder
 * 3.1.7 - unauthenticated cannot read/write to /main or /test
 * 3.1.8 - admin with tester claim can access both /main and /test
 * 3.1.9 - admin without tester claim can access both /main and /test
 * 3.2.1 - user can write to matched dataFolder
 * 3.2.2 - user cannot write to non-matched dataFolder
 * 3.2.3 - user cannot write to unknown resourceType
 * 3.3.1 - authenticated user can read data
 * 3.3.2 - user can read config public and then read matched dataFolder data
 * 3.3.3 - user cannot read data from folder that does not match public config
 * 
 * SUITE 4: NICKNAME INDEX
 * 4.1.1 - authenticated user can read any nickname entry
 * 4.1.2 - owner can create nickname entry only if it contains their own userId
 * 4.1.3 - owner can only delete nickname entry if they own it
 * 4.1.4 - non-owner cannot read or modify nicknameIndex from non-configured folder
 * 4.1.5 - admin can create/read/update/delete any nickname entry
 * 
 * SUITE 5: USERS (PUBLIC & PRIVATE PROFILES)
 * 5.1.1 - owner can create/get/update own doc with name and visibility only
 * 5.1.2 - non-owner cannot create or update someone else's doc
 * 5.1.3 - owner cannot access user doc in non-configured folder
 * 5.1.4 - delete is admin-only
 * 5.2.1 - authenticated non-owner can get a public user, but not a private one
 * 5.2.2 - only owner can update own visibility
 * 5.2.3 - authenticated non-owner can list public users only with explicit filter
 * 5.3.1 - owner can create/get/update own doc with email and lastLogin only
 * 5.3.2 - non-owner cannot read or write someone else's doc
 * 5.4.1 - owner can set and update nickname field
 * 5.4.2 - owner cannot set empty nickname
 * 5.4.3 - non-owner cannot set or modify someone else's nickname
 * 5.4.4 - owner can set visibility to private without nickname
 * =====================================================
 */

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Used indirectly by tests: All test suites (0-5) - fundamental auth check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Used indirectly by tests: 0.x.x, 1.x.x, 2.x.x, 3.x.x, 4.x.x, 5.x.x (admin operations throughout)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Used indirectly by tests: 3.1.5, 3.1.8 (role-based environment access)
    function hasTesterClaim() {
      return isAuthenticated() &&
        ('tester' in request.auth.token) &&
        request.auth.token.tester == true;
    }

    // Used indirectly by tests: 3.1.5, 3.1.8 (role-based environment access)
    function isTester() {
      return isAuthenticated() && !isAdmin() && hasTesterClaim();
    }

    // Used indirectly by tests: 3.1.6, 3.1.9 (role-based environment access)
    function isUser() {
      return isAuthenticated() && !isAdmin() && !hasTesterClaim();
    }

    // Used indirectly by tests: 3.1.5-3.1.9 (environment access split)
    function canAccessEnvironment(env) {
      return isAdmin() ||
        (env == 'main' && isUser()) ||
        (env == 'test' && isTester());
    }

    // Used indirectly by tests: 0.x.x, 1.x.x, 3.x.x, 4.x.x, 5.x.x (owner checks throughout)
    function isOwner(data, field) {
      return isAuthenticated() && (field in data) && request.auth.uid == data[field];
    }

    // Used indirectly by tests: 1.3.7-1.3.8 (collection field validation)
    function hasOnlyValidKeys(data, validKeys) { 
      return data.keys().hasOnly(validKeys);
    }
    // Used indirectly by tests: 1.3.1-1.3.3 (collection required fields), 5.1.1, 5.3.1 (user fields)
    function hasAllRequiredKeys(data, requiredKeys) {
      return data.keys().hasAll(requiredKeys);
    }
    // Used indirectly by tests: 1.5.2-1.5.4 (collection optional fields on update)
    function hasOnlyAffectedKeys(newData, existingData, validKeys) {
      return newData.diff(existingData).affectedKeys().hasOnly(validKeys);
    }
    // Used indirectly by tests: 1.5.1 (collection updatedAt required on update)
    function hasAllRequiredAffectedKeys(newData, existingData, requiredKeys) {
      return newData.diff(existingData).affectedKeys().hasAll(requiredKeys);
    }

    // Used indirectly by tests: 1.3.1, 1.3.4 (collection name), 1.3.5, 1.5.2-1.5.5 (description),
    // 5.1.1 (user name), 5.4.1-5.4.2 (nickname)
    function validString(field, maxLength) {
      return field is string && field.size() > 0 && field.size() <= maxLength;
    }

    // Used indirectly by tests: 5.3.1 (user email - optional)
    function validOptionalString(field, maxLength) {
      return field == null || (field is string && field.size() <= maxLength);
    }

    // Used indirectly by tests: 1.3.5-1.3.6, 1.5.2-1.5.3 (collection description),
    // 5.1.1 (user name), 5.3.1 (user email)
    function hasValidOptionalString(data, field, maxLength) {
      return !(field in data) || data[field] == null || validOptionalString(data[field], maxLength);
    }


    // Used indirectly by tests: 0.1.x (authorized-users), 1.1.x-1.7.x (collections),
    // 3.x.x (infrastructure), 4.x.x (nickname), 5.x.x (users)
    function validTimestamp(field) {
      return field is timestamp && 
        field.toMillis() > 0 &&
        field.toMillis() < request.time.toMillis() + 60000; // Allow up to 60 seconds in the future for clock skew
    }

    // Used indirectly by tests: 0.1.1 (authorized-users email matching)
    function tokenEmail() {
      return (isAuthenticated() && ('email' in request.auth.token) && request.auth.token.email is string)
        ? request.auth.token.email
        : (isAuthenticated() && ('authEmail' in request.auth.token) && request.auth.token.authEmail is string)
          ? request.auth.token.authEmail
          : null;
    }

    // Used indirectly by tests: 1.1.4 (public collections), 1.7.1 (query), 5.2.1 (public users), 5.2.3 (user list)
    function isPubliclyVisible() {
      return resource != null &&
        resource.data != null &&
        ('visibility' in resource.data) &&
        (resource.data.visibility is map) &&
        ('public' in resource.data.visibility) &&
        resource.data.visibility.public == true;
    }

    // Used indirectly by tests: 1.3.3, 1.3.8 (collection visibility), 1.5.4 (collection update), 5.1.1 (user public)
    function isValidVisibilityMap(data) {
      return (data is map) &&
        data.keys().hasOnly(['public']) &&
        ('public' in data) &&
        data.public is bool;
    }
    // Used indirectly by tests: 1.3.3 (collection), 5.1.1 (user visibility)
    function isValidVisibilityMapOptional(data) {
      return !('visibility' in data) || data.visibility == null || isValidVisibilityMap(data.visibility);
    }

    // Used indirectly by tests: 5.4.1 (nickname set and update), 5.4.4 (nickname with visibility)
    function hasValidNickname(data) {
      return ('nickname' in data) && validString(data.nickname, 50);
    }

    // Used indirectly by tests: 5.4.1-5.4.2 (user nickname optional/validation), 5.4.4 (visibility without nickname)
    function hasValidOptionalNickname(data) {
      return !('nickname' in data) || data.nickname == null || hasValidNickname(data);
    }

    // Used indirectly by tests: 5.4.4 (nickname required when public)
    function isPublicVisibilityEnabled(data) {
      return ('visibility' in data) &&
        isValidVisibilityMap(data.visibility) &&
        data.visibility.public == true;
    }

    function isValidPublicUserData(data) {
      return 
        data.keys().hasOnly(['name', 'visibility', 'nickname']) && // Tests 5.1.1, 5.1.2: Only allowed fields
        validString(data.name, 100) && // Test 5.1.1: Name required and max 100
        isValidVisibilityMapOptional(data) && // Tests 5.1.1, 5.2.2: Visibility validation
        hasValidOptionalNickname(data) && // Tests 5.4.1, 5.4.2: Nickname optional but valid if present
        (!isPublicVisibilityEnabled(data) || hasValidNickname(data)); // Test 5.4.4: Nickname required if public
    }

    function isValidPrivateUserData(data) {
      return 
        data.keys().hasOnly(['email', 'lastLogin']) && // Test 5.3.1: Only allowed fields
        validOptionalString(data.email, 100) && // Test 5.3.1: Email optional, max 100
        validTimestamp(data.lastLogin); // Test 5.3.1: LastLogin must be valid timestamp
    }


    // WIP:
    // function getLengthLimitUser(field) {
    //     return (field == 'name') ? 100 :
    //            (field == 'description') ? 1000 : 0;
    // }

    // function createUserKeys() {
    //     return ['name', 'createdAt', 'visibility', 'nickname'];
    // }
    // function createUserRequiredKeys() {
    //   return ['name', 'createdAt', 'visibility', 'nickname'];
    // }
    // function validUserCreate(data) {
    //   return 
    //     isAdmin() ||
    //     (
    //       isAuthenticated() &&
    //       hasOnlyValidKeys(data, createUserKeys()) &&
    //       hasAllRequiredKeys(data, createUserRequiredKeys()) &&
    //       validString(data.name, getLengthLimitUser('name')) &&
    //       validTimestamp(data.createdAt) &&
    //       isValidVisibilityMap(data.visibility) &&
    //       hasValidOptionalString(data, 'description', getLengthLimitUser('description'))
    //     );
    // }

    // Public runtime config doc - Tests 3.1.3, 3.1.4
    match /{env}/config/public/runtime {
      allow read: if canAccessEnvironment(env); // Tests 3.1.5-3.1.9: environment gate
      allow write: if canAccessEnvironment(env) && isAdmin(); // Tests 3.1.3, 3.1.4, 3.1.5-3.1.9
    }

    // All other config paths are admin-only - Tests 3.1.3, 3.1.4
    match /{env}/config/{document=**} {
      allow read, write: if canAccessEnvironment(env) && isAdmin(); // Tests 3.1.3, 3.1.4, 3.1.5-3.1.9
    }

    // Admin-only scratch area for tests and diagnostics - Tests 3.1.1, 3.1.2
    match /test/testData/{document=**} {
      allow read, write: if isAdmin();
    }

    // Folder documents themselves are not user-writable
    match /{env}/data/{folder} {
      allow read, list, write: if canAccessEnvironment(env) && isAdmin(); // Tests 3.1.5-3.1.9: env gate; admin-only on folder doc

      // Reused by nested resource rules so environment access stays explicit.
      // Tests 3.1.5-3.1.9 cover this gate across /main vs /test.
      function environmentAccessAllowed() {
        return canAccessEnvironment(env);
      }
      
      function folderMatchesConfig() {
        return get(/databases/$(database)/documents/$(env)/config/public/runtime).data.dataFolder == folder;
      }

      // authorized-users: admin-only read/write (login allowlist) - Tests 0.1.1, 0.1.2, 0.1.3
      match /private/authorized-users/{email} {
        // Test 0.1.1: Allow a signed-in user to check *only their own* authorization doc.
        // Test 0.1.2: This enables a client-side allowlist check without permitting enumeration.
        allow get: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 0.1.1
          (
            folderMatchesConfig() && // Test 3.2.1
            isAuthenticated() && // Test 0.1.1
            tokenEmail() != null && // Test 0.1.1
            tokenEmail().lower() == email.lower() // Test 0.1.1
          ));
        // Test 0.1.3: Admin can list
        allow list: if environmentAccessAllowed() && isAdmin();
        // Test 0.1.1: Admin-only write
        allow write: if environmentAccessAllowed() && isAdmin();
      }

      // users public profile: owner writes only name + visibility.public; others may read only when public - Tests 5.1.1-5.4.4
      match /public/users/{userId} {
        // Test 5.1.1, 5.1.2, 5.2.1: Get (admin, owner, or public)
        allow get: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 5.1.1
          (
            folderMatchesConfig() && // Test 5.1.3
            (isOwner({'userId': userId}, 'userId') || isPubliclyVisible()) // Test 5.1.1, 5.2.1
          ));
        // Test 5.2.1, 5.2.3: List only public users
        allow list: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 5.2.3
          (
            folderMatchesConfig() && // Test 5.2.3
            isPubliclyVisible() // Test 5.2.3
          ));
        // Test 5.1.1, 5.1.2: Create with validation
        allow create: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 5.1.1
          (
            folderMatchesConfig() && // Test 5.1.3
            isOwner({'userId': userId}, 'userId') && // Test 5.1.2
            isValidPublicUserData(request.resource.data) // Test 5.1.1, 5.4.1-5.4.4
          ));
        // Test 5.1.1, 5.1.2, 5.2.2: Update with validation
        allow update: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 5.1.1
          (
            folderMatchesConfig() && // Test 5.1.3
            isOwner({'userId': userId}, 'userId') && // Test 5.1.2
            isValidPublicUserData(request.resource.data) // Test 5.1.1, 5.2.2, 5.4.1-5.4.4
          ));
        // Test 5.1.4: Delete is admin-only
        allow delete: if environmentAccessAllowed() && isAdmin();
      }

      // users private profile: owner-only read/write for email + lastLogin - Tests 5.3.1, 5.3.2
      match /private/users/{userId} {
        // Test 5.3.1, 5.3.2: Owner-only get
        allow get: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 5.3.1
          (
            folderMatchesConfig() && // Test 5.3.2
            isOwner({'userId': userId}, 'userId') // Test 5.3.2
          ));
        // Test 5.3.1: Admin list only
        allow list: if environmentAccessAllowed() && isAdmin();
        // Test 5.3.1, 5.3.2: Owner-only create with validation
        allow create: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 5.3.1
          (
            isOwner({'userId': userId}, 'userId') && // Test 5.3.2
            folderMatchesConfig() && // Test 5.3.2
            isValidPrivateUserData(request.resource.data) // Test 5.3.1
          ));
        // Test 5.3.1, 5.3.2: Owner-only update with validation
        allow update: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 5.3.1
          (
            isOwner({'userId': userId}, 'userId') && // Test 5.3.2
            folderMatchesConfig() && // Test 5.3.2
            isValidPrivateUserData(request.resource.data) // Test 5.3.1
          ));
        // Test 5.3.1: Admin-only delete
        allow delete: if environmentAccessAllowed() && isAdmin();
      }


      // Items are now stored directly under the user document (no collections)
      match /public/users/{userId}/items/{itemId} {
        // Admin, owner, or public
        allow get: if environmentAccessAllowed() && (
          isAdmin() ||
          (folderMatchesConfig() && (isOwner({'userId': userId}, 'userId') || isPubliclyVisible()))
        );
        allow list: if environmentAccessAllowed() && (
          isAdmin() ||
          (folderMatchesConfig() && (isOwner({'userId': userId}, 'userId') || isPubliclyVisible()))
        );
        allow create: if environmentAccessAllowed() && (
          isAdmin() ||
          (isOwner({'userId': userId}, 'userId') && folderMatchesConfig() && validItemCreate(request.resource.data))
        );
        allow update: if environmentAccessAllowed() && (
          isAdmin() ||
          (isOwner({'userId': userId}, 'userId') && folderMatchesConfig() && validItemUpdate(request.resource.data, resource.data))
        );
        allow delete: if environmentAccessAllowed() && (
          isAdmin() ||
          (isOwner({'userId': userId}, 'userId') && folderMatchesConfig())
        );
      }

      // ----------------------------------------------------------------
      // items helpers -----------------------------------------------
      function getLengthLimitItem(field) {
        return (field == 'item.name') ? 100 :
               (field == 'item.description') ? 1000 : 0;
      }
      function createItemKeys() {
        return ['name', 'userId', 'createdAt', 'visibility', 'description'];
      }
      function createItemRequiredKeys() {
        return ['name', 'userId', 'createdAt', 'visibility'];
      }
      function validItemCreate(data) {
        return 
          isAdmin() ||
          (
            isAuthenticated() &&
            hasOnlyValidKeys(data, createItemKeys()) &&
            hasAllRequiredKeys(data, createItemRequiredKeys()) &&
            isOwner(data, 'userId') &&
            validString(data.name, getLengthLimitItem('item.name')) &&
            validTimestamp(data.createdAt) &&
            isValidVisibilityMap(data.visibility) &&
            hasValidOptionalString(data, 'description', getLengthLimitItem('item.description'))
          );
      }
      function updateItemKeys() {
        return ['name', 'updatedAt', 'description', 'visibility'];
      }
      function updateItemRequiredKeys() {
        return ['updatedAt'];
      }
      function validItemUpdate(newData, existingData) {
        return 
          isAdmin() ||
          (
            isAuthenticated() &&
            existingData != null &&
            hasOnlyAffectedKeys(newData, existingData, updateItemKeys()) &&
            hasAllRequiredAffectedKeys(newData, existingData, updateItemRequiredKeys()) &&
            isOwner(existingData, 'userId') &&
            newData.userId == existingData.userId &&
            newData.createdAt == existingData.createdAt &&
            validTimestamp(newData.updatedAt) &&
            hasValidOptionalString(newData, 'name', getLengthLimitItem('item.name')) &&
            hasValidOptionalString(newData, 'description', getLengthLimitItem('item.description')) &&
            isValidVisibilityMapOptional(newData.visibility)
          );
      }


      // Nickname index: track nicknames and their owners - Tests 4.1.1-4.1.5
      // Authenticated users can read nickname docs, but can only write/delete if they contain their own userId
      match /public/nicknameIndex/{nickname} {
        // Test 4.1.1: Authenticated users can read
        allow get, list: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 4.1.5
          (
            folderMatchesConfig() && // Test 4.1.4
            isAuthenticated() // Test 4.1.1
          ));
        // Test 4.1.2: Owner can create with their userId
        allow create: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 4.1.5
          (
            folderMatchesConfig() && // Test 4.1.4
            isAuthenticated() && // Test 4.1.2
            request.resource.data.userId == request.auth.uid && // Test 4.1.2
            request.resource.data.userId is string // Test 4.1.2
          ));
        // Test 4.1.2, 4.1.3: Owner can update with their userId
        allow update: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 4.1.5
          (
            folderMatchesConfig() && // Test 4.1.4
            isAuthenticated() && // Test 4.1.3
            resource.data.userId == request.auth.uid && // Test 4.1.3
            request.resource.data.userId == request.auth.uid && // Test 4.1.3
            request.resource.data.userId is string // Test 4.1.3
          ));
        // Test 4.1.3: Owner can delete if they own it
        allow delete: if 
          environmentAccessAllowed() && (
          isAdmin() || // Test 4.1.5
          (
            folderMatchesConfig() && // Test 4.1.4
            isAuthenticated() && // Test 4.1.3
            resource.data.userId == request.auth.uid // Test 4.1.3
          ));
      }
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
